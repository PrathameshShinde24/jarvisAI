# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Groq (LLM — free tier) ────────────────────────────────
# Sign up at console.groq.com — free, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile is the best free option with tool use
GROQ_MODEL=llama-3.3-70b-versatile

# ── Wake trigger (keyboard hotkey) ────────────────────────
# Press this key combo to activate Jarvis (like saying "Hey Jarvis")
# Examples: ctrl+space  ctrl+j  f9  alt+j
WAKE_HOTKEY=ctrl+space

# ── Server ────────────────────────────────────────────────
PORT=8765

# ── Security (Phase 10) ───────────────────────────────────
# Bearer token required on all non-UI API routes
API_TOKEN=
