# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Groq (LLM — free tier) ────────────────────────────────
# Sign up at console.groq.com — free, no credit card needed
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile is the best free option with tool use
GROQ_MODEL=llama-3.3-70b-versatile

# ── Wake word (openwakeword) ──────────────────────────────
# No API key needed — models download automatically on first run
# Tune sensitivity: 0.3 (more sensitive) to 0.7 (less false triggers)
WAKE_WORD_THRESHOLD=0.5

# ── Server ────────────────────────────────────────────────
PORT=8765

# ── Security (Phase 10) ───────────────────────────────────
# Bearer token required on all non-UI API routes
API_TOKEN=
